# ===========================================================================
# DevMind — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored. Never commit real secrets.
# For Railway deployment: set these in the Railway dashboard under Variables.
# For Lambda deployment: set these in the Lambda function's Configuration >
#   Environment variables panel.
#
# Variables marked [Railway] are only needed on the webhook receiver.
# Variables marked [Lambda] are only needed on the processor function.
# Variables marked [Both] are needed in both environments.
# ===========================================================================


# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# "development" | "production"
# Controls: FastAPI docs visibility (disabled in production)
ENVIRONMENT=development                          # [Both]


# ---------------------------------------------------------------------------
# LLM — Groq API
# Get your key at: https://console.groq.com
# ---------------------------------------------------------------------------

GROQ_API_KEY=                                   # [Lambda]

# Optional: fallback if Groq rate limits hit
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=                                  # [Lambda]

# Optional: HuggingFace API key for embeddings (RAG pipeline)
# Get your key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=                             # [Lambda]


# ---------------------------------------------------------------------------
# GitHub App
# Create a GitHub App at: https://github.com/settings/apps/new
# Required permissions:
#   - Pull requests: Read & write (to post review comments)
#   - Contents: Read (to fetch diffs)
# Required webhook events:
#   - Pull request
# ---------------------------------------------------------------------------

# The numeric App ID shown on your GitHub App's settings page
GITHUB_APP_ID=                                   # [Lambda]

# The RSA private key generated on your GitHub App's settings page.
# Paste the full PEM content including -----BEGIN RSA PRIVATE KEY----- header.
# In Railway/Lambda: set as a multi-line env var or use a secrets manager.
GITHUB_PRIVATE_KEY=                              # [Lambda]

# A random secret string you set when configuring the webhook on GitHub.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must match exactly what you enter in GitHub App > Webhook > Secret.
GITHUB_WEBHOOK_SECRET=                           # [Railway]


# ---------------------------------------------------------------------------
# Upstash Redis
# Get credentials at: https://console.upstash.com
# Used for: idempotency key storage (webhook deduplication)
# ---------------------------------------------------------------------------

UPSTASH_REDIS_REST_URL=                          # [Railway]
UPSTASH_REDIS_REST_TOKEN=                        # [Railway]


# ---------------------------------------------------------------------------
# Upstash QStash
# Get credentials at: https://console.upstash.com/qstash
# Used for: async message queue between webhook receiver and Lambda
# ---------------------------------------------------------------------------

# Bearer token for publishing messages to QStash
QSTASH_TOKEN=                                    # [Railway]

# Signing keys for verifying QStash → Lambda delivery (JWT verification).
# Rotate NEXT into CURRENT on each key rotation; QStash tries both during rotation window.
QSTASH_CURRENT_SIGNING_KEY=                      # [Lambda]
QSTASH_NEXT_SIGNING_KEY=                         # [Lambda]


# ---------------------------------------------------------------------------
# AWS Lambda
# The Function URL exposed by your Lambda function.
# QStash (on Railway) POSTs to this URL to trigger processing.
# Find it in Lambda console > Configuration > Function URL.
# ---------------------------------------------------------------------------

LAMBDA_FUNCTION_URL=                             # [Railway]


# ---------------------------------------------------------------------------
# Supabase (PostgreSQL + pgvector)
# Get credentials at: https://supabase.com/dashboard/project/<your-project>/settings/api
# Used for: review persistence (reviews, review_comments tables) + RAG embeddings
# ---------------------------------------------------------------------------

SUPABASE_URL=                                    # [Lambda]
SUPABASE_ANON_KEY=                               # [Lambda]

# Direct PostgreSQL connection string (used by SQLAlchemy, not the Supabase client).
# Format: postgresql+asyncpg://postgres:<password>@<host>:5432/postgres
# Find the host under: Project Settings > Database > Connection string > URI
DATABASE_URL=                                    # [Lambda]


# ---------------------------------------------------------------------------
# App configuration
# These have sensible defaults; override only if needed.
# ---------------------------------------------------------------------------

# Maximum number of review comments posted per PR (default: 15)
# CommentSynthesizerNode caps its output at this value.
MAX_COMMENTS_PER_PR=15                           # [Lambda]

# Maximum characters per diff chunk sent to the LLM (default: 20000 ≈ 5000 tokens)
MAX_CHUNK_CHARS=20000                            # [Lambda]
